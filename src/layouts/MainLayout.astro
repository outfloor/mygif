---
import { _BULL } from "../lib/chars";
import config from "../config.json";
import "../styles/global.css";

const { title: subtitle, description } = Astro.props as {
    title?: string;
    description?: string;
};

const title = subtitle
    ? `${config.base_title} ${_BULL} ${subtitle}`
    : config.base_title;
---

<html lang="en">
    <head>
        <!-- Page Metadata -->
        <meta charset="utf-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"
        />
        <meta
            name="description"
            content={description ?? config.base_description}
        />
        <title>{title}</title>
        <!-- Page Resources -->
    </head>
    <body class="bg-bg-primary text-fg-primary w-full min-h-screen relative">
        <slot />
    </body>
</html>
